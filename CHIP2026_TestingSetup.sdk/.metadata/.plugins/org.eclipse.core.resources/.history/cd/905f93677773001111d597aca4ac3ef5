err_t fn_scanin(){
	//Data of this fn is structured as : scan_id,scan_len,(8bit combined and padded scan_data)
	err_t err = 0;
	DEBUG_PRINT("Started Running scanin\n");
	u8 scan_id = GLOBAL_FN_TCP_DATA.Data_Ptr[0];
	u16 scan_len = ((u16)GLOBAL_FN_TCP_DATA.Data_Ptr[2] << 8) | (u16)GLOBAL_FN_TCP_DATA.Data_Ptr[1];
	DEBUG_PRINT("scanid = %d\n",scan_id);
	DEBUG_PRINT("scanlen = %d\n",scan_len);
	if(scan_len != GLOBAL_SM_DATA.scan_len[scan_id]){
		printf("Partial Scan In will happen\n");
	}

	//Call Scan In Function
	//c_scan_in(GLOBAL_FN_TCP_DATA.Data_Ptr + 3,scan_id,scan_len);
	//dma_send_recv_test(scan_id,scan_len);
	verilog_scan_in(GLOBAL_FN_TCP_DATA.Data_Ptr + 3,scan_id,scan_len);
	//Send expected reply
	u8 fn_name = GLOBAL_FN_TCP_DATA.fn_name;
	err = tcp_write(GLOBAL_WRITE_TCP_DATA.pcb, &fn_name, 1, TCP_WRITE_FLAG_COPY);
	u32 data_size = 1;
	err = tcp_write(GLOBAL_WRITE_TCP_DATA.pcb, &data_size, 4, TCP_WRITE_FLAG_COPY);
	u8 reply = SUCCESS_REPLY; //Send success reply
	err = transfer_data(&reply, data_size);

	//Set FN_DATA to default.
	set_fn_data_to_default();
	DEBUG_PRINT("Finished Running scanin\n");
	return err;
}

err_t fn_scanout(){
	//Data of this fn is structured as : scan_id,scan_len
	err_t err = 0;
	DEBUG_PRINT("Started Running scanout\n");
	u8 scan_id = GLOBAL_FN_TCP_DATA.Data_Ptr[0];
	u16 scan_len = ((u16)GLOBAL_FN_TCP_DATA.Data_Ptr[2] << 8) | (u32)GLOBAL_FN_TCP_DATA.Data_Ptr[1];
	DEBUG_PRINT("scanid = %d\n",scan_id);
	DEBUG_PRINT("scanlen = %d\n",scan_len);
	if(scan_len != GLOBAL_SM_DATA.scan_len[scan_id]){
		printf("Partial Scan Out will happen\n");
	}
	//Call c scan out here
	//u32 scan_out_bytes = c_scan_out(scan_id,scan_len);
	u32 scan_out_bytes = verilog_scan_out(scan_id,scan_len);
	//Send expected reply
	u8 fn_name = GLOBAL_FN_TCP_DATA.fn_name;
	err = tcp_write(GLOBAL_WRITE_TCP_DATA.pcb, &fn_name, 1, TCP_WRITE_FLAG_COPY);
	u32 data_size = scan_out_bytes;
	err = tcp_write(GLOBAL_WRITE_TCP_DATA.pcb, &data_size, 4, TCP_WRITE_FLAG_COPY);
	//Send required bytes from SCAN_OUT_BUFFER
	err = transfer_data(GLOBAL_SM_DATA.dma_scanout_buffer, data_size);

	//Set FN_DATA to default.
	set_fn_data_to_default();
	DEBUG_PRINT("Finished Running scanout\n");
	return err;
}

