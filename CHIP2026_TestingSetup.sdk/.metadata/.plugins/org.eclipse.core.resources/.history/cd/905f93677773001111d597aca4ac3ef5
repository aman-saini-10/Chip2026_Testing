err_t fn_echo(){
	xil_printf("\nStarted Running fn_echo()\n");
	err_t err = 0;
	DEBUG_PRINT("Started Running ECHO\n");

	//Echo back the data
	u8 fn_name = GLOBAL_FN_TCP_DATA.fn_name;
	err = tcp_write(GLOBAL_WRITE_TCP_DATA.pcb, &fn_name, 1, TCP_WRITE_FLAG_COPY);
	u32 data_size = GLOBAL_FN_TCP_DATA.Data_Size;
	err = tcp_write(GLOBAL_WRITE_TCP_DATA.pcb, &data_size, 4, TCP_WRITE_FLAG_COPY);
	err = transfer_data(GLOBAL_FN_TCP_DATA.Data_Ptr, data_size);

	//Set FN_DATA to default.
	set_fn_data_to_default();
	DEBUG_PRINT("Finished Running ECHO\n");
	return err;
}

err_t fn_setChipIO(){
	//Data of this fn is structured as : signal_len,{signals ndx of len}, {values of len} => total 2len + 1.
	DEBUG_PRINT("Started Running setChipIO\n");
	err_t err = 0;
	u8 signal_len = GLOBAL_FN_TCP_DATA.Data_Ptr[0];
	u8* signals = (u8*)calloc(signal_len,sizeof(u8)); //create signal array
	u8* signal_values = (u8*)calloc(signal_len,sizeof(u8)); //create values array

	memcpy(signals,GLOBAL_FN_TCP_DATA.Data_Ptr + 1,signal_len); //Copy signals into signal array
	memcpy(signal_values,GLOBAL_FN_TCP_DATA.Data_Ptr + signal_len + 1,signal_len); //Copy values into value array

	//Call the set_AXI_Bits fn
	err =  set_AXI_Bits(signals, signal_len, signal_values); //This will set the given values to given signals.

	//Send expected reply
	u8 fn_name = GLOBAL_FN_TCP_DATA.fn_name;
	err = tcp_write(GLOBAL_WRITE_TCP_DATA.pcb, &fn_name, 1, TCP_WRITE_FLAG_COPY);
	u32 data_size = 1;
	err = tcp_write(GLOBAL_WRITE_TCP_DATA.pcb, &data_size, 4, TCP_WRITE_FLAG_COPY);
	u8 reply = SUCCESS_REPLY; //Send success reply
	err = transfer_data(&reply, data_size);

	free(signals);
	free(signal_values);
	//Set FN_DATA to default.
	set_fn_data_to_default();
	DEBUG_PRINT("Finished Running setChipIO\n");
	return err;
}

