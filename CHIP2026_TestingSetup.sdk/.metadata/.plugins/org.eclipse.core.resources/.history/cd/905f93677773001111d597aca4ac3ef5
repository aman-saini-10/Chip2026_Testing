/********************** Call each function here based on function ID *****************************/
err_t process_fn(){
	err_t err=0;
	if(GLOBAL_FN_TCP_DATA.fn_name == echo){
		err = fn_echo();
	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == setChipIO){
		err = fn_setChipIO();
	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == scanin){
		err = fn_scanin();
	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == scanout){
		err = fn_scanout();
	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == readsram){
		err = fn_readSRAM();
	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == writesram){
		err = fn_writeSRAM();
	}
//	else if(GLOBAL_FN_TCP_DATA.fn_name == linear){
//		err = fn_linear();
//	}
//	else if(GLOBAL_FN_TCP_DATA.fn_name == convolution){
//		err = fn_convolution();
//	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == marchingsram){
		err = fn_marchingsram();
	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == writesrammasked){
		err = fn_writeSRAM_Masked();
	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == setModeIO){
		err = fn_setModeIO();
	}
//	else if(GLOBAL_FN_TCP_DATA.fn_name == fastCalib){
//		err = fn_fastCalib();
//	}
	else if(GLOBAL_FN_TCP_DATA.fn_name == fastimc){
		err = fn_fastimc();
	}
//	else if(GLOBAL_FN_TCP_DATA.fn_name == getcorrectiondata){
//		err = fn_getcorrectiondata();
//	}
	else{
		printf("No Valid Function Requested to RUN\n");
	}
	return err;
}


