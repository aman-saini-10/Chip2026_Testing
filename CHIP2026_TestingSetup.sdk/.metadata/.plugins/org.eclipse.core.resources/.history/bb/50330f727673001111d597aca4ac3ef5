u8 InputData_To_SRAMBuff(u8 b,u8 s,u8 c,u8 xb,u32 x_offset, u8 x_strides ,u8 x_chunks, u16 mac_len, u8 x_bits){
	//There is no ref-line issue. If X_bit is one then write 4-7 bits of 0th byte as one. and rest to be 0 which gives 240. Else write 15 which will pass 0 from DAC
	for(u16 wl = 0; wl < 1024; wl++){ // 1024 -> BANK 0 -> Chunk 0
		u8 chunk =  3 - floor(wl/256); // get chunk id here
		u16 MAC = wl%256; // get MAC id here
		//Only 0th byte needs to be taken care of
		u32 batch_offset = x_strides*x_chunks*mac_len*x_bits;
		u32 stride_offset = x_chunks*mac_len*x_bits;
		u32 chunk_offset = mac_len*x_bits;

		u8 xbit = GLOBAL_FN_TCP_DATA.Data_Ptr[x_offset + b*batch_offset + s*stride_offset +(c+chunk)*chunk_offset + MAC*x_bits + xb];
		if(xbit){
			GLOBAL_SM_DATA.sram_write_buffer[wl*40] = 240;
		}
		else{
			GLOBAL_SM_DATA.sram_write_buffer[wl*40] = 15;
		}
	}
	return 0;
}

