//Compare the data for marching pattern
//remember the data is in bytes not bits so all 0 -> 0 all 1 -> 255
u8 compare_data(u8* data, u16 len, u8 key){
	u8 matches = 1;
	for(u16 i = 0; i < len; i++){
		if(data[i] != key){
			matches = 0;
		}
	}
	return matches;
}

//Write all 0, Read 0 write 1 read 1 and move on.
u8 marching_Pattern_SRAM(){
	u8 zero_sram_array[36*1156] = {0}; //Zero array to initialize SRAM.
	u8 one_wl_array[36]; //All ones array to write in WL
	memset(one_wl_array, 0xFF, 36); // Fill with 255
	//Call Write SRAM -> Initialize to zero
	write_SRAM_Full(zero_sram_array);
	flush_wl_sc();

	//Now for each WL read 0, Write 1 and read 1
	printf("WL0 -> WL1155\n");
	for(u16 wl = 0; wl < NUM_WL; wl++){
		//Read the data and check if all zeros
		u16 scanned_bytes = read_SRAM_WL(wl);

		GLOBAL_SM_DATA.dma_scanout_buffer[33] &= 0x3F;
		u8 zero_match = compare_data(GLOBAL_SM_DATA.dma_scanout_buffer,GLOBAL_SM_DATA.scan_len[SA_OUT_SC]/8,0);
		if(!zero_match){
			printf("Zero read doesn't match for WL = %d\n",wl);
		}

		//Write one in same WL
		write_SRAM_WL(wl,one_wl_array);

		//Read one from WL and check if all ones
		scanned_bytes = read_SRAM_WL(wl);

		GLOBAL_SM_DATA.dma_scanout_buffer[33] |= 0xC0; // set the last 2 MSB to 1
		u8 one_match = compare_data(GLOBAL_SM_DATA.dma_scanout_buffer,(GLOBAL_SM_DATA.scan_len[SA_OUT_SC]+2)/8,255);
		if(!one_match){
			printf("One read doesn't match for WL = %d\n",wl);
		}
		//move WL by 1
		move_WL_SC();
	}
	set_CS(0);
	set_ScanID(0);
	return 0;
}


