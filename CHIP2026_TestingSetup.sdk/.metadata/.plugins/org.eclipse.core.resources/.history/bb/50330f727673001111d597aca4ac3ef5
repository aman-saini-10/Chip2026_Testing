							float Bias = (GLOBAL_SM_DATA.Correction_Data[1][bank][bl][dl] + GLOBAL_SM_DATA.Correction_Data[1][bank][bl+1][dl])/2;

							for (u8 j = xb; j < xb + XBL; j++) {
								int power = W_Weight + X_Weight + i + j;

								float weight = ((i == MANTISSA - 1) ^ (j == MANTISSA - 1))
