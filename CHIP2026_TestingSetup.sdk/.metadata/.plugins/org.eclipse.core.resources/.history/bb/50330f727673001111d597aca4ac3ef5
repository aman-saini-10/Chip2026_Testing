void set_nth_bit(u8 *array, u8 n) {
    size_t byte_index = n / 8;
    uint8_t bit_position = n % 8;
    array[byte_index] |= (1 << bit_position);
}

u8 WeightData_To_SRAMBuff(u8 oc,u8 c,u8 wb,u32 w_offset, u8 w_chunks, u16 mac_len, u8 w_bits){
	//This does not write the refline data and input image dac data into array. Call specific functions for it.
	//Weight bits are written in to 2 BLns to elimination meta-stability that may happen in TDC
	//Reset the buffer to 0 to eliminate last written weights. It is imprtant as bitwise or is done.
	memset(GLOBAL_SM_DATA.sram_write_buffer,0,sizeof(GLOBAL_SM_DATA.sram_write_buffer));
	u32 kn_offset = w_chunks*mac_len*w_bits;
	u32 chunk_offset = mac_len*w_bits;
	for(u16 wl = 0; wl < 1024; wl++){ // 1024 -> BANK 0 -> Chunk 0
		u8 chunk =  3 - floor(wl/256); // get chunk id here
		u16 MAC = wl%256; // get MAC id here
		u16 kn = 0;
		u16 ref_ndx = 0;
		for(u16 bl = 8; bl < 296; bl++){ //Reflines are also included which needs to be skipped. Also need to encode it in bytes.
			if(bl == GLOBAL_SM_DATA.RefLine_Index[ref_ndx%32]){ // Skip the refline
				ref_ndx++;
				GLOBAL_SM_DATA.sram_write_buffer[wl*40 + (int)(bl/8)] |= (1 << (bl%8)); //Write all references to be 1;
			}
			else{ //Encode the weight bits into SRAM_WRITE_DATA array. Hard-coded for Wb = 2

				u8 wbit = GLOBAL_FN_TCP_DATA.Data_Ptr[w_offset + (oc+(int)(kn/4))*kn_offset + (c+chunk)*chunk_offset + MAC*w_bits + (int)floor((kn%4)/2) + wb]; //((int)((kn%4)/2)
				GLOBAL_SM_DATA.sram_write_buffer[wl*40 + (int)(bl/8)] |= ((wbit) << (bl%8));
				kn++;
			}
		}
	}

	return 0;
}

