								else{
									OUT = (OUT1 + OUT2)/2;
								}
								int MAC = temp < 3 ? temp : round(OUT*Slope + Bias);
								CONV_OUT[out_idx] += MAC * weight;
								//printf("Expected: %d Got: %d Bank: %d BL: %d DL: %d \n",temp,MAC,bank,bl,dl);
								//printf("%d %f %f  %d %f %f \n" ,GLOBAL_SM_DATA.imc_out_mac[bank*4*64 + bl*64 + dl],GLOBAL_SM_DATA.Correction_Data[0][bank][bl][dl],GLOBAL_SM_DATA.Correction_Data[1][bank][bl][dl],
