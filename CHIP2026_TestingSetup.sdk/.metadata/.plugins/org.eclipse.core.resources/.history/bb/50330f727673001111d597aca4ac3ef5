u8 write_SRAM_Full(u8* write_data){
	//Float the Bitlines - > Active LOW
	{
		u8 signals[1] = {BL_PCHG};
		u8 values[1] = {1};
		set_AXI_Bits(signals,1,values);
	}
	//Flush the wordline scan chain.
	flush_wl_sc();
	//Write data will be in packets of 40bytes * 1156(number of wordlines). Ensure this in python
	for(u16 wl = 0; wl < NUM_WL; wl++){
		//Write one WL
		write_SRAM_WL_Verilog(wl,write_data+wl*40);
		//Move WL by 1
		move_WL_SC();
		//Last iteration will have WL_SCAN chain flushed out
	}
	return 0;
}

//This does not write data on calib wl
u8 write_SRAM_Masked(u8* write_data){
	//Flush the wordline scan chain.
	flush_wl_sc();
	//Write data will be in packets of 40bytes * 1156(number of wordlines). Ensure this in python
	u16 mac_wl = 0;
	u16 calib_wl_ndx = 0;
	for(u16 wl = 0; wl < NUM_WL; wl++){
		if(wl != GLOBAL_SM_DATA.calib_wl[calib_wl_ndx])
		{
			//Write one WL
			DEBUG_PRINT("Written WL = %d\n",wl);
			write_SRAM_WL_Verilog(wl,write_data+mac_wl*40);
			mac_wl ++;
		}
		else{
			DEBUG_PRINT("Skipped WL = %d\n",wl);
			calib_wl_ndx++;
		}
		//Move WL by 1
		move_WL_SC();
		//Last iteration will have WL_SCAN chain flushed out
	}
	//printf("Calibwlndx = %d\n",calib_wl_ndx);
	return 0;
}


u8 set_CS(u8 coulmn_id){
	u8 signal_array[2]= {CS_0,CS_1};
	u8 value_array[2] = {0, 0};
	switch(coulmn_id){
	case 0:
		value_array[1] = 0;value_array[0] = 0;
		break;
	case 1:
		value_array[1] = 0;value_array[0] = 1;
		break;
	case 2:
		value_array[1] = 1;value_array[0] = 0;
		break;
	case 3:
		value_array[1] = 1;value_array[0] = 1;
		break;
	}
	u8 ret = set_AXI_Bits(signal_array,2,value_array);
	//DEBUG_PRINT("CS SET\n");
	return ret;
}
u16 read_SRAM_WL(u16 wl){
	for(u8 cs = 0; cs < 3; cs++){
		//Set CS
		set_CS(cs);
		//Precharge the BLs (BL_PCHG is active low)
		{
			u8 signals[1] = {BL_PCHG};
			u8 values[1] = {0};
			set_AXI_Bits(signals,1,values);
		}
		//Set BLs floating and activate WL
		{
			u8 signals[2] = {BL_PCHG,WL_EN};
			u8 values[2] = {1,1};
			set_AXI_Bits(signals,2,values);
		}
		//Turn on SA (Active Low)
		{
			u8 signals[1] = {SA_EN};
			u8 values[1] = {0};
			set_AXI_Bits(signals,1,values);
		}
		//Turn off WL and Give CLK_SA to sample the output -> Active Low
		{
			u8 signals[2] = {WL_EN,CLK_SA};
			u8 values[2] = {0,0};
			set_AXI_Bits(signals,2,values);
		}
		//Turn off SA and CLK_SAMPLE both active low
		{
			u8 signals[2] = {SA_EN,CLK_SA};
			u8 values[2] = {1,1};
			set_AXI_Bits(signals,2,values);
		}
	}
	//Select Scan Chain
	set_ScanID(SA_OUT_SC);
	//Latch Sampled SA_OUT onto scan chain CLK_A can be high.
	{
		u8 signals[3] = {IN_EN,CLK_A,SCN_IN};
		u8 values[3] = {1,1,0};
		set_AXI_Bits(signals,3,values);
	}
	//Turn off CLK_A and after that Disable IN_EN
	{
		u8 signals[1] = {CLK_A};
		u8 values[1] = {0};
		set_AXI_Bits(signals,1,values);
	}
	{
		u8 signals[1] = {IN_EN};
		u8 values[1] = {0};
		set_AXI_Bits(signals,1,values);
	}

	//Now we are all set to scan out
	u16 scanned_bytes = verilog_scan_out(SA_OUT_SC,GLOBAL_SM_DATA.scan_len[SA_OUT_SC]); //This stores read data in dma_buffer
	return scanned_bytes;
}

u8 read_SRAM_Full(){
	//Flush the wordline scan chain.
	flush_wl_sc();

	for(u16 wl = 0; wl < NUM_WL; wl++){
		u16 scanned_bytes = read_SRAM_WL(wl);
		//Copy the scanned bytes from scan_out buffer to read_sram_buffer
		memcpy(GLOBAL_SM_DATA.sram_read_buffer + wl*scanned_bytes,GLOBAL_SM_DATA.dma_scanout_buffer,scanned_bytes);
		//Move WL by 1
		move_WL_SC();
		//Last iteration will have WL_SCAN chain flushed out
	}

	set_CS(0);
	set_ScanID(0);
	return 0;
}

