			u8 dl = kn%64;
			for (u8 ch = c; ch < c + NUM_CHUNK; ch++) {
				if(ch < GLOBAL_LINEAR_DATA.chunks_unpadded){

					u8 bank = ch%4;
					u32 w_exp_idx = w_exp_offset + kn * w_chunks * 4 + ch * 4;
					u32 W_Weight = ((u32)data_ptr[w_exp_idx + 3] << 24) |
								   ((u32)data_ptr[w_exp_idx + 2] << 16) |
								   ((u32)data_ptr[w_exp_idx + 1] << 8)  |
								   ((u32)data_ptr[w_exp_idx]);

					for (u8 bt = b; bt < b + XDL; bt++) {
						u32 x_exp_idx = x_exp_offset + bt * x_chunks * 4 + ch * 4;
						u32 X_Weight = ((u32)data_ptr[x_exp_idx + 3] << 24) |
									   ((u32)data_ptr[x_exp_idx + 2] << 16) |
									   ((u32)data_ptr[x_exp_idx + 1] << 8)  |
									   ((u32)data_ptr[x_exp_idx]);

						u32 x_data_base = sizes_data +
										  bt * x_chunks * MAC_LEN * x_bits +
										  ch * MAC_LEN * x_bits;

						u32 w_data_base = sizes_data + x_tensor_size +
										  kn * w_chunks * MAC_LEN * w_bits +
										  ch * MAC_LEN * w_bits;
						for (u8 i = wb; i < wb + WBL; i++) {
							u8 bl = 2 - 2*(i%2);  //if wb%2 0 -> 2,3 if 1-> 0,1
							int OUT1 = GLOBAL_SM_DATA.imc_out_mac[bank*4*64 + bl*64 + dl];
							int OUT2 = GLOBAL_SM_DATA.imc_out_mac[bank*4*64 + (bl+1)*64 + dl];
							float Slope = (GLOBAL_SM_DATA.Correction_Data[0][bank][bl][dl] + GLOBAL_SM_DATA.Correction_Data[0][bank][bl+1][dl])/2;
							float Bias = (GLOBAL_SM_DATA.Correction_Data[1][bank][bl][dl] + GLOBAL_SM_DATA.Correction_Data[1][bank][bl+1][dl])/2;

							for (u8 j = xb; j < xb + XBL; j++) {
								int power = W_Weight + X_Weight + i + j;
								float weight = ((i == (MANTISSA - 1)) ^ (j == (MANTISSA - 1)))
											 ? (-1 * pow(2, power))
											 : (pow(2, power));
								if((i > (MANTISSA - 1)) | (j > (MANTISSA - 1)) )
									weight = 0;
								int temp = 0;
								for (u16 n = 0; n < MAC_LEN; n++) {
									u32 x_n_offset = x_data_base + n * x_bits;
									u32 w_n_offset = w_data_base + n * w_bits;
									u8 x_bit = data_ptr[x_n_offset + j];
									u8 w_bit = data_ptr[w_n_offset + i];
									//LIN_OUT[bt * w_batch + kn] += x_bit * w_bit * weight;
									temp += x_bit * w_bit;
								}

							    float OUT;
							    if(abs(OUT1-OUT2) > 10){
							    	printf("This happened %d %d %d %d %d\n",OUT1,OUT2,bank,bl,dl);
							    	OUT = (-150<OUT1 && OUT1<10) ? OUT1 : OUT2;
							    }
							    else{
							    	OUT = (OUT1 + OUT2)/2;
							    }
							    int MAC = temp < 3 ? temp : round(OUT*Slope + Bias);
							    //int MAC = round(OUT*Slope + Bias);
								LIN_OUT[bt * w_batch + kn] += MAC * weight;
								//printf("Expected: %d Got: %d Bank: %d BL: %d DL: %d \n",temp,MAC,bank,bl,dl);
								//printf("%d %f %f  %d %f %f \n" ,GLOBAL_SM_DATA.imc_out_mac[bank*4*64 + bl*64 + dl],GLOBAL_SM_DATA.Correction_Data[0][bank][bl][dl],GLOBAL_SM_DATA.Correction_Data[1][bank][bl][dl],
								//		GLOBAL_SM_DATA.imc_out_mac[bank*4*64 + (bl+1)*64 + dl],GLOBAL_SM_DATA.Correction_Data[0][bank][bl+1][dl],GLOBAL_SM_DATA.Correction_Data[1][bank][bl+1][dl]);
							}
						}
					}
				}
			}
		}
	}

	return 0;
}

