//Write TCP data struct for global use.
#define MAX_SEND_BUFF 1446*2 //Define the packet size
#define SUCCESS_REPLY (u8)128
#define FAIL_REPLY (u8)0
#define DIG_IN_SIG_LEN 34

struct WRTIE_TCP_DATA{
	void* Data_Ptr; //Function send data pointer
	int Data_Size_To_Send; //Used internally by push data.
	int Send_Data_Flag; //Block the state machine until previous data is sent
	struct tcp_pcb* pcb; //used this channel to write back
};

extern struct WRTIE_TCP_DATA GLOBAL_WRITE_TCP_DATA;

//Global Data for linear function
struct LINEAR_DATA{
	u16 MAC_LEN;
	u8 NUM_CHUNK;
	u8 WDL;
	u8 XDL;
	u8 WBL;
	u8 XBL;
	u8 MANTISSA;
	u8 x_batch;
	u8 w_batch;
	u8 x_chunks;
	u8 w_chunks;
	u8 x_bits;
	u8 w_bits;
	u8 w_batch_unpadded;
	u8 chunks_unpadded;
	u8 sizes_data;
	//Shape of x_input_tesnsor = x_batch,x_chunks,MAC_LEN,x_bits
	u32 x_tensor_size;
	//Shape of w_input_tensor = w_batch,w_chunks,MAC_LEN,w_bits
	u32 w_tensor_size;
	//Shape of input_max_exp = x_batch,x_chunks 4bytes
	u32 x_exp_size;
	//Shape of weight_max_exp = w_batch,w_chunks 4bytes
	u32 w_exp_size;
};

extern struct LINEAR_DATA GLOBAL_LINEAR_DATA;

struct CONVOLUTION_DATA{
	u16 MAC_LEN;
	u8 NUM_STRIDE;
	u8 WDL;
	u8 XDL;
	u8 WBL;
	u8 XBL;
	u8 MANTISSA;
	u16 padded_strides;
	u8 x_batch;
	u8 w_batch;
	u16 x_stride;
	u16 w_stride;
	u8 x_chunks;
	u8 w_chunks;
	u8 x_bits;
	u8 w_bits;
	u8 w_batch_unpadded;
	u16 strides_unpadded;
	u8 sizes_data;
	//Shape of x_input_tesnsor = x_batch,x_stride,x_chunks,MAC_LEN,x_bits
	u32 x_tensor_size;
	//Shape of w_input_tensor = w_batch,w_stride(always 1),w_chunks,MAC_LEN,w_bits
	u32 w_tensor_size;
	//Shape of input_max_exp = x_batch,x_stride,x_chunks 4bytes
	u32 x_exp_size;
	//Shape of weight_max_exp = w_batch,w_stride,w_chunks 4bytes
	u32 w_exp_size;
};

extern struct CONVOLUTION_DATA GLOBAL_CONVOLUTION_DATA;

//TCP received data processing stuff
