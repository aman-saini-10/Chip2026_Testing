	linear,
	convolution,
	marchingsram,
	writesrammasked,
	setModeIO,
	fastCalib,
	fastimc,
	getcorrectiondata
} C_FUNCTIONS;


struct TCP_FUNCTION_DATA{
	C_FUNCTIONS fn_name; //function state
	u8* Data_Ptr; //Function Data pointer
	u32 Data_Size; //Size of the data to be received
	u32 Data_Recved_Size; // Size of the data actually received
	int fn_ready_flag; //Received all data from client now process the function
	int fn_data_mode; //Put TCP receive either in function or data packet mode. 0 is fn. By default it shall be in fn mode.
};

